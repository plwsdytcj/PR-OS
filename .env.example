GLM_API_KEY=
GLM_MODEL=glm-4-flash
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
RESEND_API_KEY=

# Optional Agent model adapter. Defaults to GLM and falls back to GLM_* values.
AGENT_PROVIDER=glm
AGENT_API_KEY=
AGENT_MODEL=
AGENT_BASE_URL=

# Optional Agent runtime adapter.
# openai_agents: production primary runtime through OpenAI Agents SDK
# custom: native PR OS runtime fallback / override
AGENT_RUNTIME=openai_agents
AGENT_RUNTIME_ADAPTER=
AGENT_SDK_MODEL=
AGENT_SDK_API_KEY=
AGENT_SDK_BASE_URL=
AGENT_SDK_MAX_TURNS=8
AGENT_SDK_TRACING=false
OPENAI_DEFAULT_MODEL=

# Optional OpenClaw sidecar. OC-1 uses one Gateway with per-user agent/session bindings.
OPENCLAW_ENABLED=false
OPENCLAW_GATEWAY_URL=
OPENCLAW_CONTROL_UI_URL=
OPENCLAW_ADMIN_TOKEN=
OPENCLAW_DEFAULT_AGENT_ID=kolness_default
OPENCLAW_PROXY_BASE_PATH=/openclaw

# Optional production guard. Leave empty for local development.
PR_AI_OS_ACCESS_KEY=

# Optional Phase 6A local auth. If false, auth activates automatically after the
# first local user is created with /api/auth/bootstrap-admin.
PR_AI_OS_AUTH_ENABLED=false
PR_AI_OS_COOKIE_SECURE=false

# Optional real KOL API provider.
ONEAPI_API_KEY=
ONEAPI_BASE_URL=https://api.getoneapi.com

# Optional database adapter. Empty means local SQLite.
DATABASE_URL=

# Unified object storage adapter.
# local: writes to OBJECT_STORE_LOCAL_ROOT
# oss/r2/s3/minio: S3-compatible API via boto3
OBJECT_STORE_PROVIDER=local
OBJECT_STORE_LOCAL_ROOT=data/objects
OBJECT_STORE_BUCKET=
OBJECT_STORE_ENDPOINT_URL=
OBJECT_STORE_REGION=
OBJECT_STORE_ACCESS_KEY_ID=
OBJECT_STORE_SECRET_ACCESS_KEY=
OBJECT_STORE_PUBLIC_BASE_URL=

# Optional MiroFish runtime. MiroFish is treated as an external CLI engine.
# Recommended source runtime because the current CLI fork needs its scripts/
# directory at runtime:
#   MIROFISH_COMMAND="uv --directory /opt/mirofish run mirofish"
MIROFISH_COMMAND=mirofish
MIROFISH_LLM_PROVIDER=glm
MIROFISH_PLATFORM=twitter
MIROFISH_MAX_ROUNDS=1
MIROFISH_TIMEOUT_SECONDS=420
