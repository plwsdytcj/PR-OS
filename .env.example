GLM_API_KEY=
GLM_MODEL=glm-4-flash
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# Optional production guard. Leave empty for local development.
PR_AI_OS_ACCESS_KEY=

# Optional Phase 6A local auth. If false, auth activates automatically after the
# first local user is created with /api/auth/bootstrap-admin.
PR_AI_OS_AUTH_ENABLED=false
PR_AI_OS_COOKIE_SECURE=false

# Optional real KOL API provider.
ONEAPI_API_KEY=
ONEAPI_BASE_URL=https://api.getoneapi.com

# Optional database adapter. Empty means local SQLite.
DATABASE_URL=

# Unified object storage adapter.
# local: writes to OBJECT_STORE_LOCAL_ROOT
# oss/r2/s3/minio: S3-compatible API via boto3
OBJECT_STORE_PROVIDER=local
OBJECT_STORE_LOCAL_ROOT=data/objects
OBJECT_STORE_BUCKET=
OBJECT_STORE_ENDPOINT_URL=
OBJECT_STORE_REGION=
OBJECT_STORE_ACCESS_KEY_ID=
OBJECT_STORE_SECRET_ACCESS_KEY=
OBJECT_STORE_PUBLIC_BASE_URL=
